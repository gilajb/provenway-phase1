# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_SETTINGS_MODULE=provenway.settings.development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (psycopg3)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/provenway

# Redis (Celery broker/result backend, Channels layer, cache, rate limiting)
REDIS_URL=redis://localhost:6379/0

# JWT — dev uses HS256 with DJANGO_SECRET_KEY; production REQUIRES RS256 keys below
JWT_ALGORITHM=HS256
JWT_SIGNING_KEY=
JWT_VERIFYING_KEY=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Provenway <noreply@provenway.com>

# Frontend base URL (used to build verification / reset links)
FRONTEND_BASE_URL=http://localhost:5173

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
