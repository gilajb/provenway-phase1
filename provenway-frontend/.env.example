# ── Provenway Frontend Environment Variables ─────────────────────────────────
# Copy to .env.local and fill in real values. Never commit .env.local.

# Base URL for the Django API (no trailing slash)
VITE_API_URL=http://localhost:8000/api/v1

# Cloudinary — used for direct-to-Cloudinary photo uploads
# Get these from your Cloudinary dashboard.
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=provenway_signed

# PostHog — product analytics (optional in dev)
VITE_POSTHOG_KEY=phc_your_posthog_key
VITE_POSTHOG_HOST=https://app.posthog.com

# Sentry (optional in dev — set to empty to disable)
VITE_SENTRY_DSN=
